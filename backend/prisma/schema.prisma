generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id           Int       @id @default(autoincrement())
  name         String
  tradeName    String?
  cnpj         String?   @unique
  email        String?
  phone        String?
  address           String?
  addressNumber     String?
  addressComplement String?
  neighborhood      String?
  city              String?
  state             String?
  zipCode           String?
  department        String?
  users        User[]
  roles        Role[]
  clients      Client[]
  clientStatuses ClientStatus[]
  appointments Appointment[]
  proposals    Proposal[]
  logs         Log[]
  contractTemplates ContractTemplate[]
  contracts    Contract[]
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  avatar    String?
  active    Boolean   @default(true)
  companyId Int
  company   Company   @relation(fields: [companyId], references: [id])
  roleId    Int?
  role      Role?     @relation(fields: [roleId], references: [id])
  clients   Client[]
  appointmentsAsCollaborator Appointment[] @relation("AppointmentCollaborator")
  proposalsAsCollaborator    Proposal[]    @relation("ProposalCollaborator")
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Role {
  id        Int          @id @default(autoincrement())
  name      String
  idStatus  Int          @default(1)
  companyId Int
  company   Company      @relation(fields: [companyId], references: [id])
  users     User[]
  permissions Permission[]
  deletedAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([name, companyId])
}

model Client {
  id                Int           @id @default(autoincrement())
  name              String
  email             String?
  phone             String
  document          String?
  documentType      String?
  address           String?
  addressNumber     String?
  addressComplement String?
  neighborhood      String?
  city              String?
  state             String?
  zipCode           String?
  companyId         Int
  company           Company       @relation(fields: [companyId], references: [id])
  userId            Int?
  user              User?         @relation(fields: [userId], references: [id])
  idStatus          Int?
  clientStatus      ClientStatus? @relation(fields: [idStatus], references: [id])
  appointments      Appointment[]
  proposals         Proposal[]
  contracts         Contract[]
  deletedAt         DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model ClientStatus {
  id        Int       @id @default(autoincrement())
  name      String
  color     String    @default("#6AA6C1")
  companyId Int
  company   Company   @relation(fields: [companyId], references: [id])
  clients   Client[]
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([name, companyId])
}

model Log {
  id          Int      @id @default(autoincrement())
  companyId   Int
  company     Company  @relation(fields: [companyId], references: [id])
  userId      Int?
  userName    String
  module      String
  action      String
  entityId    Int?
  entityName  String?
  description String
  metadata    Json?
  createdAt   DateTime @default(now())
}

model Permission {
  id        Int      @id @default(autoincrement())
  roleId    Int
  module    String
  action    String
  allowed   Boolean  @default(false)
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roleId, module, action])
}

model Appointment {
  id             Int       @id @default(autoincrement())
  title          String
  description    String?
  startAt        DateTime
  companyId      Int
  company        Company   @relation(fields: [companyId], references: [id])
  clientId       Int?
  client         Client?   @relation(fields: [clientId], references: [id])
  collaboratorId Int?
  collaborator   User?     @relation("AppointmentCollaborator", fields: [collaboratorId], references: [id])
  idStatus        Int       @default(1)
  statusChangedAt DateTime?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Proposal {
  id                Int       @id @default(autoincrement())
  value             Decimal
  description       String?
  clientObservation String?
  idStatus          Int       @default(1)
  statusChangedAt   DateTime?
  companyId         Int
  company           Company   @relation(fields: [companyId], references: [id])
  clientId          Int
  client            Client    @relation(fields: [clientId], references: [id])
  collaboratorId    Int?
  collaborator      User?     @relation("ProposalCollaborator", fields: [collaboratorId], references: [id])
  contracts         Contract[]
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model ContractTemplate {
  id          Int       @id @default(autoincrement())
  name        String
  content     Json
  companyId   Int
  company     Company   @relation(fields: [companyId], references: [id])
  contracts   Contract[]
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([name, companyId])
}

model Contract {
  id          Int              @id @default(autoincrement())
  name        String
  content     Json
  pdfUrl      String
  templateId  Int
  template    ContractTemplate @relation(fields: [templateId], references: [id])
  clientId    Int
  client      Client           @relation(fields: [clientId], references: [id])
  proposalId  Int
  proposal    Proposal         @relation(fields: [proposalId], references: [id])
  companyId   Int
  company     Company          @relation(fields: [companyId], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}
