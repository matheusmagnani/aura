# Produção (Neon): use o endpoint POOLED (-pooler) com pgbouncer e connect_timeout alto:
# DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.sa-east-1.aws.neon.tech/db?sslmode=require&pgbouncer=true&connection_limit=1&connect_timeout=15"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aura"
# DIRECT_URL: endpoint DIRETO (sem -pooler) — usado pelas migrations. Em dev = DATABASE_URL.
# Produção (Neon): DIRECT_URL="postgresql://user:pass@ep-xxx.sa-east-1.aws.neon.tech/db?sslmode=require"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/aura"
JWT_SECRET="your-jwt-secret-here"
PORT=3333
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
AWS_BUCKET_NAME="aura-uploads-development"
AWS_REGION="sa-east-1"
